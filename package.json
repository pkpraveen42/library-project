{
  "name": "library-purchase-app",
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "npm run server && ng serve",
    "start:frontend": "ng serve",
    "build": "ng build --base-href ./",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "server": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run start:frontend\"",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run server\" \"npm run start:frontend\" \"wait-on http://localhost:4200 && sleep 3 && cross-env NODE_ENV=development electron .\"",
    "package": "npm run build && npx electron-packager . LibraryApp --platform=win32 --arch=x64 --overwrite"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.0.3",
    "electron-packager": "^17.1.2",
    "http-proxy-middleware": "^3.0.5",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "wait-on": "^7.2.0"
  }
}
